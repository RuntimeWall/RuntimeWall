HTTP_ADDR=:8080
ENABLE_DOCKER=true
DOCKER_HOST=
SANDBOX_IMAGE=runtimewall/sandbox:latest
UBUNTU_SANDBOX_IMAGE=ubuntu:22.04
SANDBOX_NETWORK=runtimewall
SANDBOX_LABEL=runtimewall.managed

# Auto-remove stopped sandboxes older than this duration. 0 disables the sweeper.
SANDBOX_TTL=30m
SANDBOX_SWEEP_INTERVAL=1m
